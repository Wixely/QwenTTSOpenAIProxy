{
  "AllowedHosts": "*",
  "QwenBackend": {
    "BaseUrl": "http://qwen-tts:8091",
    "DefaultModel": "Qwen/Qwen3-TTS-12Hz-0.6B-Base",
    "SpeechPath": "/v1/audio/speech",
    "StreamSpeechPath": "/v1/audio/speech/stream",
    "TimeoutSeconds": 300
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  }
}
